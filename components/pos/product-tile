interface ProductTileProps {
  name: string;
  category: string;
  price: number;
  stock: number | null;
  meta: string;
}

export function ProductTile({ name, category, price, stock, meta }: ProductTileProps) {
  return (
    <article className="product-tile">
      <div className="product-tile-head">
        <div>
          <h3>{name}</h3>
          <div className="product-meta">{category}</div>
        </div>
        <span className={`badge ${stock !== null && stock < 16 ? 'warning' : ''}`}>
          {stock === null ? 'Service' : `${stock} in stock`}
        </span>
      </div>

      <div className="product-meta">{meta}</div>
      <div className="product-price">${price.toFixed(2)}</div>

      <div className="product-actions">
        <button className="small-button">Details</button>
        <button className="small-button primary">Add</button>
      </div>
    </article>
  );
}
